function scrollToOrder(paket) {
  document.getElementById('order').scrollIntoView({ behavior: 'smooth' });
  setTimeout(() => {
    const sel = document.getElementById('inputPaket');
    for(let i=0; i<sel.options.length; i++) {
      if(sel.options[i].value === paket) { sel.selectedIndex = i; break; }
    }
  }, 700);
}

// ===== SUBMIT ORDER =====
function submitOrder() {
  const nama = document.getElementById('inputNama').value.trim();
  const wa   = document.getElementById('inputWA').value.trim();
  const layanan = document.getElementById('inputLayanan').value;
  const paket   = document.getElementById('inputPaket').value;
  const rankNow = document.getElementById('inputRankNow').value.trim();
  const rankTarget = document.getElementById('inputRankTarget').value.trim();
  const catatan = document.getElementById('inputCatatan').value.trim();

  if(!nama || !wa || !layanan || !paket) {
    alert('Mohon isi Nama, Nomor WA, Layanan, dan Paket terlebih dahulu!'); return;
  }

  const msg = encodeURIComponent(
    `Halo Fix Joki! Saya mau order 🎮\n\n` +
    `👤 Nama: ${nama}\n` +
    `📱 WA: ${wa}\n` +
    `🎯 Layanan: ${layanan}\n` +
    `📦 Paket: ${paket}\n` +
    `⚔️ Rank Saat Ini: ${rankNow || '-'}\n` +
    `🏆 Target Rank: ${rankTarget || '-'}\n` +
    `📝 Catatan: ${catatan || '-'}\n\n` +
    `Mohon info lebih lanjut, terima kasih!`
  );
  window.open(`https://wa.me/6289681722000?text=${msg}`, '_blank');
}
</script>
