<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fix Joki — Mobile Legends Boosting #1</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600;700&family=Exo+2:ital,wght@0,300;0,600;0,800;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --cyan: #00d4ff;
  --purple: #7c3aed;
  --gold: #f59e0b;
  --dark: #020408;
  --dark2: #070d1a;
  --dark3: #0d1832;
  --text: #c8d8f0;
  --text-muted: #5a7090;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Exo 2', sans-serif;
  background: var(--dark);
  color: var(--text);
  overflow-x: hidden;
  cursor: none;
}

/* Custom cursor */
.cursor {
  position: fixed;
  width: 12px; height: 12px;
  background: var(--cyan);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.1s;
  mix-blend-mode: screen;
}
.cursor-ring {
  position: fixed;
  width: 36px; height: 36px;
  border: 1.5px solid var(--cyan);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  opacity: 0.5;
  transition: transform 0.15s, width 0.2s, height 0.2s;
}

/* Particle canvas */
#particles { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }

/* ===== NAV ===== */
nav {
  position: fixed; top: 0; width: 100%; z-index: 100;
  padding: 18px 48px;
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(180deg, rgba(2,4,8,0.95) 0%, transparent 100%);
  backdrop-filter: blur(6px);
  border-bottom: 1px solid rgba(0,212,255,0.08);
}
.nav-logo {
  font-family: 'Orbitron', sans-serif;
  font-size: 22px; font-weight: 900;
  background: linear-gradient(90deg, var(--cyan), #fff, var(--purple));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 2px;
}
.nav-links { display: flex; gap: 36px; list-style: none; }
.nav-links a {
  font-family: 'Rajdhani', sans-serif;
  font-size: 15px; font-weight: 700;
  color: var(--text-muted);
  text-decoration: none;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  transition: color 0.2s;
  position: relative;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0;
  width: 0; height: 1.5px;
  background: var(--cyan);
  transition: width 0.25s;
}
.nav-links a:hover { color: var(--cyan); }
.nav-links a:hover::after { width: 100%; }
.nav-cta {
  background: linear-gradient(135deg, var(--cyan), var(--purple));
  color: #fff !important;
  padding: 10px 24px;
  border-radius: 6px;
  font-weight: 700 !important;
  letter-spacing: 1px;
  -webkit-text-fill-color: #fff !important;
  transition: box-shadow 0.2s, transform 0.2s !important;
}
.nav-cta:hover { box-shadow: 0 0 24px rgba(0,212,255,0.5); transform: translateY(-1px); }
.nav-cta::after { display: none !important; }

/* ===== HERO ===== */
#hero {
  position: relative;
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  overflow: hidden;
  z-index: 1;
}
.hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(0,80,160,0.25) 0%, rgba(124,58,237,0.10) 50%, transparent 80%);
}
.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
  background-size: 50px 50px;
  mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
}
.hero-content { position: relative; z-index: 2; padding: 0 20px; }
.hero-badge {
  display: inline-block;
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px; font-weight: 700;
  letter-spacing: 4px;
  color: var(--gold);
  border: 1px solid rgba(245,158,11,0.4);
  padding: 6px 20px; border-radius: 20px;
  background: rgba(245,158,11,0.07);
  margin-bottom: 28px;
  animation: fadeUp 0.8s ease both;
}
.hero-title {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(52px, 9vw, 110px);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -1px;
  margin-bottom: 8px;
  animation: fadeUp 0.9s 0.1s

/* scroll indicator */
.scroll-hint {
  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  opacity: 0.4; animation: bounce 2s infinite;
}
.scroll-hint span { font-size: 11px; letter-spacing: 3px; font-family: 'Rajdhani'; }
.scroll-arrow { width: 1px; height: 40px; background: linear-gradient(var(--cyan), transparent); }

/* ===== SECTIONS ===== */
section { position: relative; z-index: 1; }
.section-header { text-align: center; margin-bottom: 60px; }
.section-tag {
  font-family: 'Rajdhani', sans-serif;
  font-size: 12px; font-weight: 700;
  letter-spacing: 4px; text-transform: uppercase;
  color: var(--cyan); margin-bottom: 14px;
  display: block;
}
.section-title {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(28px, 5vw, 46px);
  font-weight: 900; color: #fff; line-height: 1.1;
}
.section-title em {
  font-style: normal;
  background: linear-gradient(135deg, var(--cyan), var(--purple));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.section-desc {
  color: var(--text-muted); font-size: 16px; max-width: 480px;
  margin: 16px auto 0; line-height: 1.7;
}

/* ===== PRICELIST ===== */
#pricelist {
  padding: 120px 48px;
  background: linear-gradient(180deg, var(--dark) 0%, var(--dark2) 50%, var(--dark) 100%);
}
.price-tabs {
  display: flex; justify-content: center; gap: 8px;
  margin-bottom: 48px; flex-wrap: wrap;
}
.tab-btn {
  font-family: 'Rajdhani', sans-serif;
  font-size: 14px; font-weight: 700; letter-spacing: 1px;
  padding: 10px 24px; border-radius: 6px;
  border: 1.5px solid rgba(0,212,255,0.2);
  background: transparent; color: var(--text-muted);
  cursor: pointer; transition: all 0.2s;
}
.tab-btn.active, .tab-btn:hover {
  border-color: var(--cyan); color: var(--cyan);
  background: rgba(0,212,255,0.08);
  box-shadow: 0 0 16px rgba(0,212,255,0.15);
}
.price-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px; max-width: 1100px; margin: 0 auto;
}
.price-card {
  background: linear-gradient(145deg, rgba(13,24,50,0.9), rgba(7,13,26,0.95));
  border: 1px solid rgba(0,212,255,0.12);
  border-radius: 16px; padding: 32px 28px;
  position: relative; overflow: hidden;
  transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
}
.price-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--cyan), transparent);
  opacity: 0; transition: opacity 0.25s;
}
.price-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(0,212,255,0.12); border-color: rgba(0,212,255,0.35); }
.price-card:hover::before { opacity: 1; }
.price-card.featured {
  border-color: var(--gold);
  background: linear-gradient(145deg, rgba(20,15,5,0.95), rgba(10,8,2,0.98));
  box-shadow: 0 0 40px rgba(245,158,11,0.12);
}
.price-card.featured::before { background: linear-gradient(90deg, transparent, var(--gold), transparent); opacity: 1; }
.featured-badge {
  position: absolute; top: 16px; right: 16px;
  background: var(--gold); color: #000;
  font-family: 'Rajdhani', sans-serif;
  font-size: 11px; font-weight: 700; letter-spacing: 1px;
  padding: 4px 12px; border-radius: 20px;
}
.rank-icon { font-size: 42px; margin-bottom: 14px; }
.rank-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 15px; font-weight: 700; color: #fff;
  letter-spacing: 1px; margin-bottom: 6px;
}
.rank-range {
  font-size: 13px; color: var(--text-muted);
  font-family: 'Rajdhani'; letter-spacing: 0.5px;
  margin-bottom: 20px;
}
.rank-price {
  font-family: 'Orbitron', sans-serif;
  font-size: 28px; font-weight: 900;
  color: var(--cyan); margin-bottom: 4px;
}
.price-card.featured .rank-price { color: var(--gold); }
.rank-unit { font-size: 12px; color: var(--text-muted); font-family: 'Rajdhani'; margin-bottom: 24px; }
.rank-features { list-style: none; margin-bottom: 28px; }
.rank-features li {
  font-size: 14px; color: var(--text-muted);
  padding: 5px 0;
  display: flex; align-items: center; gap: 8px;
}
.rank-features li::before { content: '✦'; color: var(--cyan); font-size: 10px; }
.price-card.featured .rank-features li::before { color: var(--gold); }
.order-btn {
  width: 100%;
  background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(124,58,237,0.15));
  border: 1.5px solid rgba(0,212,255,0.3);
  color: var(--cyan); font-family: 'Rajdhani', sans-serif;
  font-size: 15px; font-weight: 700; letter-spacing: 1.5px;
  padding: 13px; border-radius: 8px; cursor: pointer;
  transition: all 0.2s; text-transform: uppercase;
}
.order-btn:hover { background: linear-gradient(135deg, var(--cyan), var(--purple)); color: #fff; border-color: transparent; box-shadow: 0 8px 24px rgba(0,212,255,0.3); }
.price-card.featured .order-btn { border-color: rgba(245,158,11,0.4); color: var(--gold); background: rgba(245,158,11,0.1); }
.price-card.featured .order-btn:hover { background: linear-gradient(135deg, var(--gold), #f97316); color: #000; border-color: transparent; box-shadow: 0 8px 24px rgba(245,158,11,0.3); }

/* ===== ORDER FORM ===== */
#order {
  padding: 120px 48px;
  background: var(--dark2);
}
.order-wrapper {
  max-width: 680px; margin: 0 auto;
  background: linear-gradient(145deg, rgba(13,24,50,0.8), rgba(7,13,26,0.9));
  border: 1px solid rgba(0,212,255,0.15);
  border-radius: 20px; padding: 52px 48px;
  position: relative; overflow: hidden;
}
.order-wrapper::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--purple), var(--cyan), var(--gold));
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.form-group { margin-bottom: 22px; }
.form-group.full { grid-column: 1 / -1; }
.form-label {
  display: block;
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--text-muted); margin-bottom: 8px;
}
.form-input, .form-select, .form-textarea {
  width: 100%;
  backicon svg { width: 56px; height: 56px; display: block; margin: 0 auto 14px; }
.rank-icons-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 18px; max-width: 1100px; margin: 0 auto 40px;
}
.rank-icon-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(0,212,255,0.12);
  border-radius: 18px; padding: 24px 18px; text-align: center;
}
.rank-icon-card span {
  display: block;
  margin-top: 10px;
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px; font-weight: 700;
  letter-spacing: 1px; color: #fff; text-transform: uppercase;
}
.rank-ground: rgba(0,212,255,0.04);
  border: 1.5px solid rgba(0,212,255,0.15);
  border-radius: 8px; color: var(--text);
  font-family: 'Exo 2', sans-serif; font-size: 15px;
  padding: 14px 18px;
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
  -webkit-appearance: none;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: var(--cyan);
  box-shadow: 0 0 0 3px rgba(0,212,255,0.08);
  background: rgba(0,212,255,0.06);
}
.form-select { cursor: pointer; }
.form-select option { background: var(--dark3); }
.form-textarea { min-height: 100px; resize: vertical; }
.form-submit {
  width: 100%;
  background: linear-gradient(135deg, var(--cyan), var(--purple));
  color: #fff; border: none;
  font-family: 'Rajdhani', sans-serif;
  font-size: 18px; font-weight: 700; letter-spacing: 2px;
  padding: 18px; border-radius: 8px; cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  text-transform: uppercase; margin-top: 8px;
}
.form-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,212,255,0.35); }
.form-note {
  text-align: center; font-size: 13px;
  color: var(--text-muted); margin-top: 16px;
}
.form-note span { color: var(--gold); }

/* ===== TESTIMONIALS ===== */
#testimoni {
  padding: 120px 48px;
  background: linear-gradient(180deg, var(--dark) 0%, rgba(7,13,26,0.5) 100%);
}
.testi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 22px; max-width: 1100px; margin: 0 auto;
}
.testi-card {
  background: linear-gradient(145deg, rgba(13,24,50,0.8), rgba(7,13,26,0.9));
  border: 1px solid rgba(0,212,255,0.1);
  border-radius: 16px; padding: 30px 28px;
  position: relative; overflow: hidden;
  transition: transform 0.25s, border-color 0.25s;
}
.testi-card:hover { transform: translateY(-4px); border-color: rgba(0,212,255,0.28); }
.testi-quote {
  font-size: 48px; line-height: 1;
  color: rgba(0,212,255,0.15);
  font-family: Georgia, serif;
  position: absolute; top: 16px; right: 22px;
}
.stars { color: var(--gold); font-size: 16px; margin-bottom: 14px; letter-spacing: 2px; }
.testi-text { font-size: 15px; color: var(--text); line-height: 1.7; margin-bottom: 24px; font-style: italic; }
.testi-user { display: flex; align-items: center; gap: 14px; }
.testi-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: linear-gradient(135deg, var(--cyan), var(--purple));
  display: flex; align-items: center; justify-content: center;
  font-family: 'Orbitron', sans-serif; font-size: 16px; font-weight: 900; color: #fff;
  flex-shrink: 0;
}
.testi-name { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 15px; color: #fff; }
.testi-rank { font-size: 13px; color: var(--cyan); font-family: 'Rajdhani'; }

/* ===== CONTACT ===== */
#kontak {
  padding: 120px 48px 80px;
  background: var(--dark2);
}
.contact-wrapper {
  max-width: 700px; margin: 0 auto; text-align: center;
}
.contact-cards {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 20px; margin-top: 52px;
}
.contact-card {
  background: linear-gradient(145deg, rgba(13,24,50,0.9), rgba(7,13,26,0.95));
  border: 1.5px solid rgba(0,212,255,0.15);
  border-radius: 16px; padding: 40px 30px;
  text-decoration: none; color: inherit;
  transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  display: flex; flex-direction: column; align-items: center; gap: 14px;
}
.contact-card:hover { transform: translateY(-6px); border-color: var(--cyan); box-shadow: 0 20px 60px rgba(0,212,255,0.15); }
.contact-card.ig:hover { border-color: #e1306c; box-shadow: 0 20px 60px rgba(225,48,108,0.15); }
.contact-icon { font-size: 48px; }
.contact-label {
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px; font-weight: 700; letter-spacing: 2px;
  color: var(--text-muted); text-transform: uppercase;
}
.contact-value {
  font-family: 'Orbitron', sans-serif;
  font-size: 16px; font-weight: 700; color: #fff;
}
.contact-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 24px; border-radius: 6px;
  font-family: 'Rajdhani'; font-size: 14px; font-weight: 700; letter-spacing: 1px;
  border: 1px solid rgba(0,212,255,0.3); color: var(--cyan);
  transition: all 0.2s;
}
.contact-card:hover .contact-btn { background: var(--cyan); color: #000; border-color: var(--cyan); }
.contact-card.ig:hover .contact-btn { background: #e1306c; color: #fff; border-color: #e1306c; }

/* ===== FOOTER ===== */
footer {
  background: var(--dark);
  border-top: 1px solid rgba(0,212,255,0.07);
  padding: 40px 48px;
  text-align: center;
}
.footer-logo {
  font-family: 'Orbitron', sans-serif;
  font-size: 20px; font-weight: 900;
  background: linear-gradient(90deg, var(--cyan), var(--purple));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  margin-bottom: 12px;
}
.footer-text { font-size: 13px; color: var(--text-muted); font-family: 'Rajdhani'; letter-spacing: 1px; }

/* ===== DIVIDER ===== */
.divider {
  max-width: 1100px; margin: 0 auto;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,212,255,0.2), transparent);
}

/* ===== ANIMATIONS ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 20px rgba(0,212,255,0.2); }
  50% { box-shadow: 0 0 50px rgba(0,212,255,0.5); }
}

/* Reveal on scroll */
.reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }

/* Floating glow orbs */
.orb {
  position: fixed; border-radius: 50%;
  pointer-events: none; filter: blur(80px); opacity: 0.12; z-index: 0;
}
.orb1 { width: 500px; height: 500px; background: var(--purple); top: -150px; right: -150px; }
.orb2 { width: 400px; height: 400px; background: var(--cyan); bottom: 10%; left: -100px; }

/* Mobile */
@media (max-width: 768px) {
  nav { padding: 16px 24px; }
  .nav-links { display: none; }
  #hero, #pricelist, #order, #testimoni, #kontak { padding-left: 24px; padding-right: 24px; }
  .form-row { grid-template-columns: 1fr; }
  .order-wrapper { padding: 36px 24px; }
  .contact-cards { grid-template-columns: 1fr; }
  .hero-stats { gap: 32px; }
}
@media (max-width: 480px) {
  .price-grid { grid-template-columns: 1fr; }
  .testi-grid { grid-template-columns: 1fr; }
}
</style>
</head>
